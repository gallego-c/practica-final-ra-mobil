<launch>
  <arg name="world_frame" default="map"/>
  <arg name="merged_map_topic" default="/merged_map"/>

  <!-- Connect the global world_frame (map) to each robot's map frame. 
       This completes the TF tree: map -> robotN/map -> robotN/odom -> robotN/base_footprint -->
  <node pkg="tf2_ros" type="static_transform_publisher"
        name="robot1_static_map_to_map"
        args="0 0 0 0 0 0 $(arg world_frame) robot1/map"/>

  <node pkg="tf2_ros" type="static_transform_publisher"
        name="robot2_static_map_to_map"
        args="0 0 0 0 0 0 $(arg world_frame) robot2/map"/>

  <group ns="robot1">
    <node pkg="move_base" type="move_base" name="move_base" output="screen"
          respawn="true" respawn_delay="3">
      <remap from="odom" to="/robot1/odom"/>
      <remap from="scan" to="/robot1/scan_filtered"/>
      <remap from="cmd_vel" to="/robot1/cmd_vel_raw"/>
      <remap from="map" to="/robot1/map"/>
      <rosparam file="$(find ctf_navigation)/params/move_base_slam.yaml" command="load"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common_slam.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common_slam.yaml"
                command="load" ns="local_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_global_slam.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_local_slam.yaml"
                command="load" ns="local_costmap"/>
      <param name="global_costmap/robot_base_frame" value="robot1/base_footprint"/>
      <param name="local_costmap/robot_base_frame" value="robot1/base_footprint"/>
      <!-- Option C (hybrid): explorer uses merged map; move_base costmap uses per-robot SLAM. -->
      <param name="global_costmap/global_frame" value="robot1/map"/>
      <param name="global_costmap/static_layer/map_topic" value="/robot1/map"/>
      <param name="local_costmap/global_frame" value="robot1/odom"/>
      <param name="local_costmap/obstacle_layer/scan/topic" value="/robot1/scan_filtered"/>
      <param name="local_costmap/obstacle_layer/other_robot/topic" value="/robot1/other_robot_cloud"/>
      <param name="local_costmap/obstacle_layer/other_robot/sensor_frame" value="$(arg world_frame)"/>
      <param name="local_costmap/obstacle_layer/scan/observation_persistence" value="0.0"/>
      <param name="local_costmap/obstacle_layer/other_robot/observation_persistence" value="0.0"/>
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <rosparam file="$(find ctf_navigation)/params/planner_global_slam_nav.yaml"
                command="load" ns="GlobalPlanner"/>
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find ctf_navigation)/params/planner_local_dwa_slam.yaml"
                command="load" ns="DWAPlannerROS"/>
    </node>
  </group>

  <!-- Stagger robot2 move_base so both DWA instances do not init at once (CPU spike). -->
  <group ns="robot2">
    <node pkg="move_base" type="move_base" name="move_base" output="screen"
          respawn="true" respawn_delay="3"
          launch-prefix="bash -c 'sleep 6; $0 $@' ">
      <remap from="odom" to="/robot2/odom"/>
      <remap from="scan" to="/robot2/scan_filtered"/>
      <remap from="cmd_vel" to="/robot2/cmd_vel_raw"/>
      <remap from="map" to="/robot2/map"/>
      <rosparam file="$(find ctf_navigation)/params/move_base_slam.yaml" command="load"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common_slam.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common_slam.yaml"
                command="load" ns="local_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_global_slam.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_local_slam.yaml"
                command="load" ns="local_costmap"/>
      <param name="global_costmap/robot_base_frame" value="robot2/base_footprint"/>
      <param name="local_costmap/robot_base_frame" value="robot2/base_footprint"/>
      <!-- Option C (hybrid): per-robot SLAM map for move_base global costmap. -->
      <param name="global_costmap/global_frame" value="robot2/map"/>
      <param name="global_costmap/static_layer/map_topic" value="/robot2/map"/>
      <param name="local_costmap/global_frame" value="robot2/odom"/>
      <param name="local_costmap/obstacle_layer/scan/topic" value="/robot2/scan_filtered"/>
      <param name="local_costmap/obstacle_layer/other_robot/topic" value="/robot2/other_robot_cloud"/>
      <param name="local_costmap/obstacle_layer/other_robot/sensor_frame" value="$(arg world_frame)"/>
      <param name="local_costmap/obstacle_layer/scan/observation_persistence" value="0.0"/>
      <param name="local_costmap/obstacle_layer/other_robot/observation_persistence" value="0.0"/>
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <rosparam file="$(find ctf_navigation)/params/planner_global_slam_nav.yaml"
                command="load" ns="GlobalPlanner"/>
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find ctf_navigation)/params/planner_local_dwa_slam.yaml"
                command="load" ns="DWAPlannerROS"/>
    </node>
  </group>
</launch>
