<launch>
  <!-- world: ctf_world | nine_rooms_world | hallway_world | hallway_obstacles_world -->
  <arg name="world" default="ctf_world"/>
  <arg name="robot1_x" default="$(eval -3.5 if arg('world') in ['hallway_world', 'hallway_obstacles_world'] else -3.0)"/>
  <arg name="robot1_y" default="$(eval 0.0 if arg('world') in ['hallway_world', 'hallway_obstacles_world'] else -3.0)"/>
  <arg name="robot1_yaw" default="0.0"/>
  <arg name="robot2_x" default="$(eval 3.5 if arg('world') in ['hallway_world', 'hallway_obstacles_world'] else 3.0)"/>
  <arg name="robot2_y" default="$(eval 0.0 if arg('world') in ['hallway_world', 'hallway_obstacles_world'] else 3.0)"/>
  <arg name="robot2_yaw" default="3.1416"/>

  <!-- Posición de la bandera. Cámbiala para hacer pruebas:
       roslaunch ctf_navigation ctf_game.launch flag_x:=2.0 flag_y:=-3.0 -->
  <arg name="flag_x" default="$(eval 0.0 if arg('world') in ['hallway_world', 'hallway_obstacles_world', 'nine_rooms_world'] else -3.2)"/>
  <arg name="flag_y" default="$(eval 0.0 if arg('world') in ['hallway_world', 'hallway_obstacles_world', 'nine_rooms_world'] else 3.2)"/>

  <!-- Published for multi-robot coordinators (see /ctf_navigation/spawns). -->
  <rosparam param="/ctf_navigation/spawns/robot1" subst_value="True">[$(arg robot1_x), $(arg robot1_y), $(arg robot1_yaw)]</rosparam>
  <rosparam param="/ctf_navigation/spawns/robot2" subst_value="True">[$(arg robot2_x), $(arg robot2_y), $(arg robot2_yaw)]</rosparam>
  <rosparam param="/ctf_navigation/spawns/flag" subst_value="True">[$(arg flag_x), $(arg flag_y)]</rosparam>
  <param name="/ctf_navigation/world" value="$(arg world)"/>

  <!-- Keep Gazebo transport discovery local. This avoids intermittent WSL
       discovery failures when Gazebo advertises internal topics such as
       /robot1/joint_cmd. -->
  <env name="GAZEBO_IP" value="127.0.0.1"/>
  <env name="GAZEBO_MASTER_URI" value="http://127.0.0.1:11345"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find ctf_navigation)/worlds/$(arg world).world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- ── Bandera CTF (spawn dinámico con posición configurable) ──────────────-->
  <param name="ctf_flag_description"
         textfile="$(find ctf_navigation)/models/ctf_flag.urdf"/>
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_ctf_flag" output="screen"
        args="-urdf -model ctf_flag
              -x $(arg flag_x) -y $(arg flag_y) -z 0.0
              -param ctf_flag_description"/>

  <group ns="robot1">
    <param name="tf_prefix" value="robot1"/>
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_waffle_pi.urdf.xacro"/>

    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen">
      <param name="publish_frequency" value="50.0"/>
      <remap from="/tf" to="/tf"/>
      <remap from="/tf_static" to="/tf_static"/>
    </node>

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot1" output="screen"
          args="-urdf -model robot1
                -x $(arg robot1_x) -y $(arg robot1_y) -z 0.0 -Y $(arg robot1_yaw)
                -param robot_description
                -robot_namespace /robot1"/>
  </group>

  <group ns="robot2">
    <param name="tf_prefix" value="robot2"/>
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_waffle_pi.urdf.xacro"/>

    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen">
      <param name="publish_frequency" value="50.0"/>
      <remap from="/tf" to="/tf"/>
      <remap from="/tf_static" to="/tf_static"/>
    </node>

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot2" output="screen"
          args="-urdf -model robot2
                -x $(arg robot2_x) -y $(arg robot2_y) -z 0.0 -Y $(arg robot2_yaw)
                -param robot_description
                -robot_namespace /robot2"/>
  </group>
</launch>
