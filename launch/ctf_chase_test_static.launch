<launch>
  <!-- ==========================================================================
       PRUEBA DE FASE 2 (PERSECUCIÓN) – MAPA ESTÁTICO CONOCIDO

       Inicia el juego directamente en la fase de persecución (chase) sin pasar
       por la fase de exploración/captura.  El carrier (robot1) aparece cerca de
       la bandera y debe volver a su base; el pursuer (robot2) aparece en un punto
       configurable del mapa libre de obstáculos.

       Uso (pursuer_slot es obligatorio: 1-10 o custom):
         roslaunch ctf_navigation ctf_chase_test_static.launch pursuer_slot:=4

       Posición personalizada del pursuer:
         roslaunch ctf_navigation ctf_chase_test_static.launch \
           pursuer_slot:=custom pursuer_x:=2.0 pursuer_y:=-2.5 pursuer_yaw:=1.57

       Listar los 10 puntos predefinidos (flag list):
         rosrun ctf_navigation pick_pursuer_spawn.py

       Puedes cambiar qué robot es el carrier con:
         roslaunch ctf_navigation ctf_chase_test_static.launch \
           initial_carrier_robot:=1
       ========================================================================== -->

  <arg name="local_planner"          default="dwa"/>
  <arg name="rviz"                   default="true"/>

  <!-- Flag position -->
  <arg name="flag_x"                 default="-3.2"/>
  <arg name="flag_y"                 default="3.2"/>

  <!-- Carrier (robot1): half the previous distance from flag, facing west -->
  <arg name="carrier_x"              default="-2.37"/>
  <arg name="carrier_y"              default="2.86"/>
  <arg name="carrier_yaw"            default="3.1416"/>

  <!-- Pursuer (robot2): REQUIRED pursuer_slot (1-10 or custom); see params/pursuer_spawn_points.yaml -->
  <arg name="pursuer_slot"/>
  <arg name="pursuer_x"              default="none"/>
  <arg name="pursuer_y"              default="none"/>
  <arg name="pursuer_yaw"            default="none"/>
  <arg name="pursuer_x_final"        default="$(eval float(arg('pursuer_x')) if arg('pursuer_slot') == 'custom' else [2.00, 2.50, 0.00, 0.50, -4.00, 3.20, -4.00, 1.20, -4.00, 3.00][int(arg('pursuer_slot')) - 1])"/>
  <arg name="pursuer_y_final"        default="$(eval float(arg('pursuer_y')) if arg('pursuer_slot') == 'custom' else [-2.50, 1.00, -2.80, 2.80, -1.00, -1.00, 1.50, 1.50, -3.50, -3.00][int(arg('pursuer_slot')) - 1])"/>
  <arg name="pursuer_yaw_final"      default="$(eval float(arg('pursuer_yaw')) if arg('pursuer_slot') == 'custom' else [1.5708, 3.1416, 1.5708, -1.5708, 0.7854, 3.1416, 0.0, -2.3562, 0.7854, 2.3562][int(arg('pursuer_slot')) - 1])"/>

  <!-- Which robot is the initial carrier (0 = robot1, 1 = robot2) -->
  <arg name="initial_carrier_robot"  default="0"/>

  <!-- Intercept tuning (velocity-aware algorithm) -->
  <arg name="pursuer_nav_speed"      default="0.20"/>
  <arg name="carrier_speed_window"   default="4.0"/>
  <arg name="intercept_margin_time"  default="1.5"/>

  <!-- Resolved spawn (check with rosparam get /ctf_chase_spawn) -->
  <rosparam param="/ctf_chase_spawn">
    pursuer_slot: $(arg pursuer_slot)
    carrier: {x: $(arg carrier_x), y: $(arg carrier_y), yaw: $(arg carrier_yaw)}
    pursuer: {x: $(arg pursuer_x_final), y: $(arg pursuer_y_final), yaw: $(arg pursuer_yaw_final)}
  </rosparam>

  <!-- ── 1. Gazebo Simulation ──────────────────────────────────────────────── -->
  <include file="$(find ctf_navigation)/launch/simulation.launch">
    <arg name="robot1_x"   value="$(arg carrier_x)"/>
    <arg name="robot1_y"   value="$(arg carrier_y)"/>
    <arg name="robot1_yaw" value="$(arg carrier_yaw)"/>
    <arg name="robot2_x"   value="$(arg pursuer_x_final)"/>
    <arg name="robot2_y"   value="$(arg pursuer_y_final)"/>
    <arg name="robot2_yaw" value="$(arg pursuer_yaw_final)"/>
    <arg name="flag_x"     value="$(arg flag_x)"/>
    <arg name="flag_y"     value="$(arg flag_y)"/>
  </include>

  <!-- ── 2. Inter-robot collision avoidance ───────────────────────────────── -->
  <node pkg="ctf_navigation" type="robot_obstacle_publisher_node"
        name="robot_obstacle_publisher" output="screen"/>

  <!-- ── 3. Navigation (static map_server + move_base) ────────────────────── -->
  <include file="$(find ctf_navigation)/launch/navigation.launch">
    <arg name="local_planner" value="$(arg local_planner)"/>
    <arg name="localization"  value="static"/>
  </include>

  <!-- ── 4. Flag detector (needed for flag_estimate subscription) ─────────── -->
  <group ns="robot1">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector"
          output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision.yaml" command="load"/>
      <param name="camera_topic"            value="camera/rgb/image_raw"/>
      <param name="compressed_camera_topic" value="camera/rgb/image_raw/compressed"/>
      <param name="base_frame"              value="robot1/base_footprint"/>
      <param name="map_frame"               value="map"/>
    </node>
  </group>

  <group ns="robot2">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector"
          output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision.yaml" command="load"/>
      <param name="camera_topic"            value="camera/rgb/image_raw"/>
      <param name="compressed_camera_topic" value="camera/rgb/image_raw/compressed"/>
      <param name="base_frame"              value="robot2/base_footprint"/>
      <param name="map_frame"               value="map"/>
    </node>
  </group>

  <!-- ── 5. CTF Coordinator – start directly in chase phase ──────────────── -->
  <node pkg="ctf_navigation" type="ctf_coordinator_node" name="ctf_coordinator"
        output="screen">
    <param name="map_frame"       value="map"/>
    <param name="map_topic"       value="/map"/>
    <param name="detector_node"   value="flag_detector"/>
    <param name="flag_x"          value="$(arg flag_x)"/>
    <param name="flag_y"          value="$(arg flag_y)"/>

    <param name="robot1_ns"         value="robot1"/>
    <param name="robot2_ns"         value="robot2"/>
    <param name="robot1_base_frame" value="robot1/base_footprint"/>
    <param name="robot2_base_frame" value="robot2/base_footprint"/>

    <param name="robot1_base_x"   value="-3.0"/>
    <param name="robot1_base_y"   value="-3.0"/>
    <param name="robot1_base_yaw" value="0.0"/>
    <param name="robot2_base_x"   value="3.0"/>
    <param name="robot2_base_y"   value="3.0"/>
    <param name="robot2_base_yaw" value="3.1416"/>

    <!-- Skip exploration: jump straight to chase -->
    <param name="start_phase"            value="chase"/>
    <param name="initial_carrier_robot"  value="$(arg initial_carrier_robot)"/>

    <!-- Velocity-aware intercept parameters -->
    <param name="pursuer_nav_speed"     value="$(arg pursuer_nav_speed)"/>
    <param name="carrier_speed_window"  value="$(arg carrier_speed_window)"/>
    <param name="carrier_min_speed"     value="0.05"/>
    <param name="intercept_margin_time" value="$(arg intercept_margin_time)"/>
    <param name="intercept_look_back"   value="0.5"/>
    <param name="goal_snap_clearance"       value="0.30"/>
    <param name="goal_snap_search_radius"   value="2.0"/>
    <param name="chase_startup_delay"       value="5.0"/>

    <!-- Intercept / chase tuning (kept from ctf_game.launch defaults) -->
    <param name="catch_distance"                    value="0.65"/>
    <param name="waypoint_reached_dist"             value="0.55"/>
    <param name="chase_flag_clearance"              value="0.75"/>
    <param name="chase_clearance_reached_dist"      value="0.20"/>
    <param name="chase_clearance_min_travel"        value="0.25"/>
    <param name="intercept_enabled"                 value="true"/>
    <param name="intercept_direct_chase_distance"   value="1.25"/>
    <param name="intercept_arrival_margin"          value="0.30"/>
    <param name="intercept_step"                    value="0.25"/>
    <param name="intercept_min_lead"                value="1.0"/>
    <param name="intercept_carrier_move_threshold"  value="1.25"/>
    <param name="carrier_home_resend_cooldown"      value="3.0"/>
    <param name="carrier_home_stuck_timeout"        value="6.0"/>
    <param name="carrier_home_progress_threshold"   value="0.10"/>
    <param name="direct_chase_refresh_sec"          value="2.0"/>
    <param name="direct_chase_carrier_move"         value="0.25"/>
    <param name="capture_pause_sec"                 value="1.0"/>
    <param name="flag_capture_distance"             value="0.40"/>
    <param name="flag_standoff_distance"            value="0.20"/>
    <param name="flag_memory_timeout"               value="5.0"/>
    <param name="rate_hz"                           value="5.0"/>
    <param name="explore_step"                      value="1.0"/>
    <param name="explore_clearance"                 value="0.30"/>
    <param name="map_wait_timeout"                  value="60.0"/>
    <param name="trail_min_distance"                value="0.05"/>
    <param name="trail_max_poses"                   value="2000"/>
  </node>

  <!-- ── 6. RViz ──────────────────────────────────────────────────────────── -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz"
        args="-d $(find ctf_navigation)/rviz/ctf_game.rviz"/>
</launch>
