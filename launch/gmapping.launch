<launch>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping"
        ns="robot1" output="screen">
    <remap from="scan" to="/robot1/scan"/>
    <param name="base_frame" value="robot1/base_footprint"/>
    <param name="odom_frame" value="robot1/odom"/>
    <param name="map_frame"  value="map"/>
    <param name="map_update_interval" value="2.0"/>
    <param name="maxUrange" value="3.5"/>
    <param name="minimumScore" value="200"/>
    <param name="linearUpdate"  value="0.5"/>
    <param name="angularUpdate" value="0.436"/>
    <param name="particles" value="80"/>
    <param name="xmin" value="-6.0"/>
    <param name="ymin" value="-6.0"/>
    <param name="xmax" value="6.0"/>
    <param name="ymax" value="6.0"/>
    <param name="delta" value="0.05"/>
  </node>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping"
        ns="robot2" output="screen">
    <remap from="scan" to="/robot2/scan"/>
    <param name="base_frame" value="robot2/base_footprint"/>
    <param name="odom_frame" value="robot2/odom"/>
    <param name="map_frame"  value="map"/>
    <param name="map_update_interval" value="2.0"/>
    <param name="maxUrange" value="3.5"/>
    <param name="minimumScore" value="200"/>
    <param name="linearUpdate"  value="0.5"/>
    <param name="angularUpdate" value="0.436"/>
    <param name="particles" value="80"/>
    <param name="xmin" value="-6.0"/>
    <param name="ymin" value="-6.0"/>
    <param name="xmax" value="6.0"/>
    <param name="ymax" value="6.0"/>
    <param name="delta" value="0.05"/>
  </node>

</launch>
