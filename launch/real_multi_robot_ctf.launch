<launch>
  <param name="/use_sim_time" value="false"/>

  <arg name="world_frame" default="map"/>
  <arg name="merged_map_topic" default="/merged_map"/>
  <arg name="rviz" default="true"/>

  <!-- Robots reales: ±1.5 m del centro (3 m entre ellos), cara a cara en +X -->
  <arg name="robot1_x" default="-1.50"/>
  <arg name="robot1_y" default="0.0"/>
  <arg name="robot1_yaw" default="0.0"/>
  <arg name="robot2_x" default="1.50"/>
  <arg name="robot2_y" default="0.0"/>
  <arg name="robot2_yaw" default="3.1416"/>
  <arg name="flag_x" default="0.0"/>
  <arg name="flag_y" default="0.0"/>

  <!-- lidar_yaw: rotación base_link->base_scan. 0 = URDF stock; 3.1416 solo si LD08 montado físicamente al revés -->
  <arg name="lidar_yaw" default="0.0"/>
  <!-- false si el bringup del robot ya publica base_footprint->base_link->base_scan -->
  <arg name="publish_kinematic_tf" default="true"/>

  <!-- Spawns en map (deben coincidir con map_merge init_pose y slam_navigation static TF) -->
  <rosparam param="/ctf_navigation/spawns/robot1" subst_value="True">[$(arg robot1_x), $(arg robot1_y), $(arg robot1_yaw)]</rosparam>
  <rosparam param="/ctf_navigation/spawns/robot2" subst_value="True">[$(arg robot2_x), $(arg robot2_y), $(arg robot2_yaw)]</rosparam>
  <rosparam param="/ctf_navigation/spawns/flag" subst_value="True">[$(arg flag_x), $(arg flag_y)]</rosparam>

  <arg name="quiet_slam" default="true"/>

  <!--
    Multi-PC real robots:
    1. Sync clocks: sudo timedatectl set-ntp true  (on ALL 3 PCs)
    2. STOP every ROS node on every PC (roscore included)
    3. Verify: date  and  rostopic echo /robot1/odom/header/stamp  differ < 2 s
    4. Start roscore, then robot bringups, then this launch
    5. Bringup MUST publish namespaced TF: robotN/odom -> robotN/base_footprint
       (check: rosrun tf2_tools view_frames.py  — one tree, not two)

    A ~7200 s extrapolation error almost always means NTP stepped the clock while
    ROS was still running — full restart is required, not just chrony.
  -->
  <node pkg="ctf_navigation" type="clock_drift_check.py" name="clock_drift_check" output="screen"/>

  <!-- base_footprint -> base_link -> base_scan (evita atajo directo a base_scan que desalinea láser y mapas) -->
  <include file="$(find ctf_navigation)/launch/real_robot_tf.launch">
    <arg name="lidar_yaw" value="$(arg lidar_yaw)"/>
    <arg name="publish_kinematic_tf" value="$(arg publish_kinematic_tf)"/>
  </include>

  <!-- 1. Shared SLAM (GMapping for both robots & map_merge) -->
  <include file="$(find ctf_navigation)/launch/shared_slam.launch">
    <arg name="world_frame" value="$(arg world_frame)"/>
    <arg name="merged_map_topic" value="$(arg merged_map_topic)"/>
    <arg name="quiet_slam" value="$(arg quiet_slam)"/>
    <arg name="robot1_spawn_x" value="$(arg robot1_x)"/>
    <arg name="robot1_spawn_y" value="$(arg robot1_y)"/>
    <arg name="robot1_spawn_yaw" value="$(arg robot1_yaw)"/>
    <arg name="robot2_spawn_x" value="$(arg robot2_x)"/>
    <arg name="robot2_spawn_y" value="$(arg robot2_y)"/>
    <arg name="robot2_spawn_yaw" value="$(arg robot2_yaw)"/>
    <arg name="lidar_yaw" value="$(arg lidar_yaw)"/>
    <arg name="robot1_init_x" value="$(arg robot1_x)"/>
    <arg name="robot1_init_y" value="$(arg robot1_y)"/>
    <arg name="robot1_init_yaw" value="$(arg robot1_yaw)"/>
    <arg name="robot2_init_x" value="$(arg robot2_x)"/>
    <arg name="robot2_init_y" value="$(arg robot2_y)"/>
    <arg name="robot2_init_yaw" value="$(arg robot2_yaw)"/>
  </include>

  <!-- 2. Inter-robot priority coordination & collision avoidance -->
  <node pkg="ctf_navigation" type="robot_coordinator.py"
        name="robot_coordinator" output="screen">
    <param name="target_frame" value="$(arg world_frame)"/>
    <param name="robot_radius" value="0.28"/>
    <param name="max_avoid_distance" value="3.5"/>
    <param name="use_odom_relative" value="true"/>
    <rosparam param="robot1_spawn" subst_value="True">[$(arg robot1_x), $(arg robot1_y), $(arg robot1_yaw)]</rosparam>
    <rosparam param="robot2_spawn" subst_value="True">[$(arg robot2_x), $(arg robot2_y), $(arg robot2_yaw)]</rosparam>
  </node>

  <!-- 3. Navigation (move_base) for both robots on the /merged_map -->
  <include file="$(find ctf_navigation)/launch/slam_navigation.launch">
    <arg name="world_frame" value="$(arg world_frame)"/>
    <arg name="merged_map_topic" value="$(arg merged_map_topic)"/>
    <arg name="robot1_x" value="$(arg robot1_x)"/>
    <arg name="robot1_y" value="$(arg robot1_y)"/>
    <arg name="robot1_yaw" value="$(arg robot1_yaw)"/>
    <arg name="robot2_x" value="$(arg robot2_x)"/>
    <arg name="robot2_y" value="$(arg robot2_y)"/>
    <arg name="robot2_yaw" value="$(arg robot2_yaw)"/>
    <!-- Real: wait for gmapping + scans before costmaps request map->base_footprint -->
    <arg name="move_base_delay_robot1" value="10"/>
    <arg name="move_base_delay_robot2" value="14"/>
  </include>

  <!-- 4. Visión: detector de bandera por robot (Configurado para robots reales) -->
  <group ns="robot1">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector" output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision_real.yaml" command="load"/>
      <param name="camera_topic" value=""/>
      <param name="compressed_camera_topic" value="cv_camera/image_raw/compressed"/>
      <param name="scan_topic" value="scan"/>
      <param name="base_frame" value="robot1/base_footprint"/>
      <param name="map_frame" value="$(arg world_frame)"/>
    </node>
  </group>

  <group ns="robot2">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector" output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision_real.yaml" command="load"/>
      <param name="camera_topic" value=""/>
      <param name="compressed_camera_topic" value="cv_camera/image_raw/compressed"/>
      <param name="scan_topic" value="scan"/>
      <param name="base_frame" value="robot2/base_footprint"/>
      <param name="map_frame" value="$(arg world_frame)"/>
    </node>
  </group>

  <!-- 5. Autonomous exploration + CTF Game Coordinator -->
  <node pkg="ctf_navigation" type="slam_frontier_explorer_ctf.py"
        name="slam_frontier_explorer_ctf" output="screen" required="true">
    <param name="map_frame" value="$(arg world_frame)"/>
    <param name="map_topic" value="$(arg merged_map_topic)"/>
    
    <!-- Todos los parametros originales del CTF aquí -->
    <param name="exploration_timeout" value="300.0"/>
    <param name="goal_timeout" value="45.0"/>
    <param name="min_coverage" value="0.72"/>
    <param name="gain_scale" value="2.0"/>
    <param name="log_mode" value="brief"/>
    <param name="flag_collision_radius" value="0.03"/>
    <param name="flag_standoff_distance" value="0.20"/>
    <param name="flag_capture_margin" value="0.08"/>
    <param name="flag_capture_distance" value="0.60"/>
    <!-- Evita captura falsa al arrancar: exige persecución real antes de capturar -->
    <param name="flag_capture_min_pursuit_sec" value="4.0"/>
    <param name="flag_capture_min_progress" value="0.20"/>
    <param name="chase_home_min_travel_from_capture" value="0.50"/>

    <rosparam param="robot1_home" subst_value="True">[$(arg robot1_x), $(arg robot1_y), $(arg robot1_yaw)]</rosparam>
    <rosparam param="robot2_home" subst_value="True">[$(arg robot2_x), $(arg robot2_y), $(arg robot2_yaw)]</rosparam>
  </node>

  <!-- 6. RViz -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz"
        args="-d $(find ctf_navigation)/rviz/slam_multi_robot_ctf.rviz"/>
</launch>
