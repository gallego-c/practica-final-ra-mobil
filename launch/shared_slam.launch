<launch>
  <arg name="robot1_map_frame" default="robot1/map"/>
  <arg name="robot2_map_frame" default="robot2/map"/>
  <arg name="shared_map_frame" default="map"/>
  <arg name="publish_tf_bridges" default="true"/>
  <arg name="use_map_merger" default="true"/>

  <!-- Each robot builds its own map frame. Keeping these frames separate avoids
       two gmapping nodes publishing conflicting map -> odom transforms. -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping"
        ns="robot1" output="screen">
    <remap from="scan" to="/robot1/scan"/>
    <rosparam file="$(find ctf_navigation)/params/gmapping_robot1.yaml"
              command="load"/>
    <param name="base_frame" value="robot1/base_footprint"/>
    <param name="odom_frame" value="robot1/odom"/>
    <param name="map_frame" value="$(arg robot1_map_frame)"/>
  </node>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping"
        ns="robot2" output="screen">
    <remap from="scan" to="/robot2/scan"/>
    <rosparam file="$(find ctf_navigation)/params/gmapping_robot2.yaml"
              command="load"/>
    <param name="base_frame" value="robot2/base_footprint"/>
    <param name="odom_frame" value="robot2/odom"/>
    <param name="map_frame" value="$(arg robot2_map_frame)"/>
  </node>

  <!-- Initial frame bridges for the shared map. They are intentionally isolated
       in this launch so experiments can replace them with real map alignment. -->
  <node if="$(arg publish_tf_bridges)"
        pkg="tf2_ros" type="static_transform_publisher"
        name="shared_map_to_robot1_map"
        args="0 0 0 0 0 0 $(arg shared_map_frame) $(arg robot1_map_frame)"/>

  <node if="$(arg publish_tf_bridges)"
        pkg="tf2_ros" type="static_transform_publisher"
        name="shared_map_to_robot2_map"
        args="0 0 0 0 0 0 $(arg shared_map_frame) $(arg robot2_map_frame)"/>

  <node if="$(arg use_map_merger)"
        pkg="ctf_navigation" type="shared_map_merger.py"
        name="shared_map_merger" output="screen">
    <param name="robot1_map_topic" value="/robot1/map"/>
    <param name="robot2_map_topic" value="/robot2/map"/>
    <param name="merged_map_topic" value="/map"/>
    <param name="frame_id" value="$(arg shared_map_frame)"/>
    <param name="publish_rate" value="1.0"/>
  </node>
</launch>
