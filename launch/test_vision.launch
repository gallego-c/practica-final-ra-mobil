<launch>
  <!-- Launch file for testing vision without autonomous movement -->
  <arg name="world_frame" default="map"/>
  <arg name="merged_map_topic" default="/merged_map"/>
  <arg name="world" default="ctf_world"/>
  
  <arg name="robot1_x" default="-3.0"/>
  <arg name="robot1_y" default="-3.0"/>
  <arg name="robot1_yaw" default="0.0"/>
  <arg name="robot2_x" default="3.0"/>
  <arg name="robot2_y" default="3.0"/>
  <arg name="robot2_yaw" default="3.1416"/>
  <!-- Pon la bandera justo delante del robot1 para probar -->
  <arg name="flag_x" default="-2.0"/>
  <arg name="flag_y" default="-3.0"/>

  <!-- 1. Gazebo -->
  <include file="$(find ctf_navigation)/launch/simulation.launch">
    <arg name="world" value="$(arg world)"/>
    <arg name="robot1_x" value="$(arg robot1_x)"/>
    <arg name="robot1_y" value="$(arg robot1_y)"/>
    <arg name="robot1_yaw" value="$(arg robot1_yaw)"/>
    <arg name="robot2_x" value="$(arg robot2_x)"/>
    <arg name="robot2_y" value="$(arg robot2_y)"/>
    <arg name="robot2_yaw" value="$(arg robot2_yaw)"/>
    <arg name="flag_x" value="$(arg flag_x)"/>
    <arg name="flag_y" value="$(arg flag_y)"/>
  </include>

  <!-- 2. Shared SLAM (necesario para el árbol TF map->odom->base_footprint) -->
  <include file="$(find ctf_navigation)/launch/shared_slam.launch">
    <arg name="world_frame" value="$(arg world_frame)"/>
    <arg name="merged_map_topic" value="$(arg merged_map_topic)"/>
  </include>

  <!-- 3. Visión: detector de bandera por robot -->
  <group ns="robot1">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector" output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision.yaml" command="load"/>
      <param name="camera_topic" value="camera/rgb/image_raw"/>
      <param name="compressed_camera_topic" value="camera/rgb/image_raw/compressed"/>
      <param name="scan_topic" value="scan"/>
      <param name="base_frame" value="robot1/base_footprint"/>
      <param name="map_frame" value="$(arg world_frame)"/>
    </node>
  </group>

  <group ns="robot2">
    <node pkg="ctf_navigation" type="flag_detector_node" name="flag_detector" output="screen">
      <rosparam file="$(find ctf_navigation)/params/vision.yaml" command="load"/>
      <param name="camera_topic" value="camera/rgb/image_raw"/>
      <param name="compressed_camera_topic" value="camera/rgb/image_raw/compressed"/>
      <param name="scan_topic" value="scan"/>
      <param name="base_frame" value="robot2/base_footprint"/>
      <param name="map_frame" value="$(arg world_frame)"/>
    </node>
  </group>

  <!-- RViz -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find ctf_navigation)/rviz/slam_multi_robot_ctf.rviz"/>

  <!-- NOTA: Hemos omitido move_base y slam_frontier_explorer_ctf.py, 
       por lo que los robots se quedarán completamente quietos. -->
</launch>
