<launch>
  <arg name="map_file" default="$(find ctf_navigation)/maps/ctf_map.yaml"/>

  <!-- Servidor de mapa compartido -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)"/>

  <!-- ===== NAVEGACIÓN ROBOT 1 ===== -->
  <group ns="robot1">

    <node pkg="amcl" type="amcl" name="amcl" output="screen">
      <remap from="scan" to="/robot1/scan"/>
      <param name="use_map_topic" value="true"/>
      <param name="odom_frame_id"  value="robot1/odom"/>
      <param name="base_frame_id"  value="robot1/base_footprint"/>
      <param name="global_frame_id" value="map"/>
      <param name="initial_pose_x" value="-3.0"/>
      <param name="initial_pose_y" value="-3.0"/>
      <param name="initial_pose_a" value="0.0"/>
      <param name="initial_cov_xx" value="0.1"/>
      <param name="initial_cov_yy" value="0.1"/>
      <param name="initial_cov_aa" value="0.1"/>
      <param name="min_particles"  value="500"/>
      <param name="max_particles"  value="2000"/>
      <param name="update_min_d"   value="0.2"/>
      <param name="update_min_a"   value="0.2"/>
      <param name="laser_max_range" value="3.5"/>
      <param name="odom_model_type" value="diff"/>
    </node>

    <node pkg="move_base" type="move_base" name="move_base" output="screen">
      <remap from="odom"  to="/robot1/odom"/>
      <remap from="scan"  to="/robot1/scan"/>
      <remap from="cmd_vel" to="/robot1/cmd_vel"/>
      <rosparam file="$(find ctf_navigation)/params/move_base.yaml" command="load"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common.yaml"
                command="load" ns="local_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_global.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_local.yaml"
                command="load" ns="local_costmap"/>
      <param name="global_costmap/robot_base_frame" value="robot1/base_footprint"/>
      <param name="local_costmap/robot_base_frame"  value="robot1/base_footprint"/>
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <rosparam file="$(find ctf_navigation)/params/planner_global.yaml"
                command="load" ns="GlobalPlanner"/>
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find ctf_navigation)/params/planner_local_dwa.yaml"
                command="load" ns="DWAPlannerROS"/>
    </node>

  </group>

  <!-- ===== NAVEGACIÓN ROBOT 2 ===== -->
  <group ns="robot2">

    <node pkg="amcl" type="amcl" name="amcl" output="screen">
      <remap from="scan" to="/robot2/scan"/>
      <param name="use_map_topic" value="true"/>
      <param name="odom_frame_id"  value="robot2/odom"/>
      <param name="base_frame_id"  value="robot2/base_footprint"/>
      <param name="global_frame_id" value="map"/>
      <param name="initial_pose_x" value="3.0"/>
      <param name="initial_pose_y" value="3.0"/>
      <param name="initial_pose_a" value="3.1416"/>
      <param name="initial_cov_xx" value="0.1"/>
      <param name="initial_cov_yy" value="0.1"/>
      <param name="initial_cov_aa" value="0.1"/>
      <param name="min_particles"  value="500"/>
      <param name="max_particles"  value="2000"/>
      <param name="update_min_d"   value="0.2"/>
      <param name="update_min_a"   value="0.2"/>
      <param name="laser_max_range" value="3.5"/>
      <param name="odom_model_type" value="diff"/>
    </node>

    <node pkg="move_base" type="move_base" name="move_base" output="screen">
      <remap from="odom"  to="/robot2/odom"/>
      <remap from="scan"  to="/robot2/scan"/>
      <remap from="cmd_vel" to="/robot2/cmd_vel"/>
      <rosparam file="$(find ctf_navigation)/params/move_base.yaml" command="load"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_common.yaml"
                command="load" ns="local_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_global.yaml"
                command="load" ns="global_costmap"/>
      <rosparam file="$(find ctf_navigation)/params/costmap_local.yaml"
                command="load" ns="local_costmap"/>
      <param name="global_costmap/robot_base_frame" value="robot2/base_footprint"/>
      <param name="local_costmap/robot_base_frame"  value="robot2/base_footprint"/>
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <rosparam file="$(find ctf_navigation)/params/planner_global.yaml"
                command="load" ns="GlobalPlanner"/>
      <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
      <rosparam file="$(find ctf_navigation)/params/planner_local_dwa.yaml"
                command="load" ns="DWAPlannerROS"/>
    </node>

  </group>

</launch>
